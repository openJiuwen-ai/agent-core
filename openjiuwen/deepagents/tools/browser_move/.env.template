# # managed browser
BROWSER_DRIVER=managed
BROWSER_PROFILE_NAME=huawei_test

# Set BROWSER_MANAGED_KILL_EXISTING=true to close any running Chrome that holds
# the same user-data-dir, then relaunch it with remote-debugging enabled.
# WARNING: this closes all open Chrome windows.
# When BROWSER_MANAGED_USER_DATA_DIR is not set, the OS-standard default Chrome
# profile path is used automatically (e.g. %LOCALAPPDATA%\Google\Chrome\User Data
# on Windows). Set it explicitly only if you need a non-default profile.

# BROWSER_MANAGED_KILL_EXISTING=true
# BROWSER_MANAGED_USER_DATA_DIR=

# remote browser 
# BROWSER_DRIVER=remote
# PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222

# # playwright extension browser 
# BROWSER_DRIVER=extension
# PLAYWRIGHT_MCP_EXTENSION_TOKEN=

# Runtime guardrails
BROWSER_TIMEOUT_S=180
PLAYWRIGHT_TOOL_TIMEOUT_S=180


