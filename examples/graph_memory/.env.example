# Graph Memory E2E test – fill in your model service endpoints and keys.
# Load with: dotenv.load_dotenv(".env")

# ---------------------------------------------------------------------------
# LLM (for entity/relation extraction and merging)
# ---------------------------------------------------------------------------
JIUWEN_GRAPH_MEM_LLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/
JIUWEN_GRAPH_MEM_LLM_MODEL=qwen3-8b
# Optional JSON: temperature, timeout, structured_output, etc.
JIUWEN_GRAPH_MEM_LLM_CONFIG={"temperature": 0.6, "timeout": 60, "structured_output": false}

# ---------------------------------------------------------------------------
# Embedding (for entity/relation/episode vectors)
# ---------------------------------------------------------------------------
JIUWEN_GRAPH_MEM_EMBED_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/
JIUWEN_GRAPH_MEM_EMBED_MODEL=text-embedding-v4
# Optional JSON: dim, timeout, etc.
JIUWEN_GRAPH_MEM_EMBED_CONFIG={"dim": 1024, "timeout": 30}

# ---------------------------------------------------------------------------
# Reranker (optional; set JIUWEN_GRAPH_MEM_RERANK_ENABLE=false to disable)
# ---------------------------------------------------------------------------
JIUWEN_GRAPH_MEM_RERANK_ENABLE=true
JIUWEN_GRAPH_MEM_RERANK_URL=https://dashscope.aliyuncs.com/api/v1
JIUWEN_GRAPH_MEM_RERANK_MODEL=qwen3-rerank
JIUWEN_GRAPH_MEM_RERANK_CONFIG={"timeout": 60}

# ---------------------------------------------------------------------------
# Graph store (Milvus)
# ---------------------------------------------------------------------------
# Milvus URI, e.g. http://localhost:19530
JIUWEN_GRAPH_MEM_MILVUS_URI="http://localhost:19530"
# Database name inside Milvus
JIUWEN_GRAPH_MEM_MILVUS_DB_NAME=graph_memory_test

DASHSCOPE_API_KEY=
