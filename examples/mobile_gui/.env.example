# Copy to examples/mobile_gui/.env and fill in values (file is gitignored).

# --- LLM (vision / multimodal model required) ---
# Aliases API_KEY / API_BASE / MODEL_NAME / MODEL_PROVIDER also work.
LLM_PROVIDER=OpenAI
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4.1-mini
LLM_SSL_VERIFY=false

# --- Device & task ---
DEVICE_SERIAL=emulator-5554
# MOBILE_TASK=Open Chrome and search for weather in Singapore.

# --- Agent loop ---
MAX_ITERATIONS=30
AGENT_TEMPERATURE=0.7

# --- Multimodal context summarizer ---
MCS_REASONING_FALLBACK_MAX_CHARS=400
MCS_ERROR_OUTCOME_MAX_CHARS=140
MCS_SCREENSHOTS_TO_KEEP=3

# --- Dialogue compressor (mobile_agent_builder) ---
MOBILE_CONTEXT_MAX_MESSAGES=120
MOBILE_CONTEXT_WINDOW_ROUNDS=20
DIALOGUE_COMPRESSOR_TOKENS_THRESHOLD=50000
DIALOGUE_COMPRESSOR_MESSAGES_TO_KEEP=60

# --- GUI tools / tiktoken placeholder patch ---
WAIT_GUI_LOAD_MIN_SECONDS=0.5
WAIT_GUI_LOAD_MAX_SECONDS=30.0
WAIT_GUI_LOAD_DEFAULT_SECONDS=2.0
SCROLL_DEFAULT_WIDTH=1080
SCROLL_DEFAULT_HEIGHT=1920
SCROLL_DURATION_MS_DEFAULT=300
TIKTOKEN_IMAGE_PLACEHOLDER_TOKENS=1445
SCREENSHOT_INTERVAL_SECONDS=2.0

# --- Multimodal skill consult ---
# branch: skill_tool runs a side branch; ToolMessage returns planner memo
# inline: legacy path — full SKILL text + read_file for skill reference images
MULTIMODAL_SKILL_CONSULT_MODE=branch
MULTIMODAL_SKILL_BRANCH_MAX_IMAGES=4
MULTIMODAL_SKILL_BRANCH_MAX_CONSULTS_PER_SKILL=2
MULTIMODAL_SKILL_BRANCH_PREVIOUS_STEPS_TURNS=10

# --- Mobile GUI trajectory ---
SCREENSHOT_SIMILARITY_MAX_MEAN_DELTA=5.0
TRAJECTORY_CLASSIFICATION_QUEUE_SIZE=100
TRAJECTORY_RENAME_WITH_CATEGORY=true
CLASSIFIER_MODEL_NAME=qwen/qwen3.6-flash
AGENT_ACTION_SUMMARIZE=true
AGENT_ACTION_MAX_LEN=80

# --- Coordinator subagent example (run_mobile_gui_subagent.py) ---
# MOBILE_COORDINATOR_DEFAULT_HINT=1
# MOBILE_COORDINATOR_SYSTEM_PROMPT=
# MOBILE_SUBAGENT_MAX_ITERATIONS=30
# OTHER_SUBAGENT_MAX_ITERATIONS=25
